{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/cron/price", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/news", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/alerts", "schedule": "*/2 * * * *" },
    { "path": "/api/cron/sentiment", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/whales", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/digest", "schedule": "0 8 * * *" },
    { "path": "/api/cron/impact", "schedule": "0 * * * *" }
  ]
}
