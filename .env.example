# Server
PORT=3000
NODE_ENV=production
APP_URL=https://yourdomain.com
BASE_URL=https://yourdomain.com

# Database (default: ./data/wavedge.db)
# DATABASE_PATH=/data/wavedge.db

# Authentication
JWT_SECRET=change-me-to-a-random-secret

# Anthropic (AI summaries, classification, digest)
ANTHROPIC_API_KEY=

# CoinGecko
COINGECKO_API_KEY=

# Stripe (Pro tier billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Telegram (alerts & digest)
TELEGRAM_BOT_TOKEN=
