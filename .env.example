# Server
PORT=3000
NODE_ENV=production
APP_URL=https://yourdomain.com
BASE_URL=https://yourdomain.com

# PostgreSQL (Cloud SQL or local)
DATABASE_URL=postgresql://wavedge:password@localhost:5432/wavedge
# For Cloud SQL via Unix socket:
# DATABASE_URL=postgresql://wavedge:password@/wavedge?host=/cloudsql/PROJECT:REGION:INSTANCE

# Authentication
JWT_SECRET=change-me-to-a-random-secret

# Anthropic (AI summaries, classification, digest)
ANTHROPIC_API_KEY=

# CoinGecko
COINGECKO_API_KEY=

# Stripe (Pro tier billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Telegram (alerts & digest)
TELEGRAM_BOT_TOKEN=
