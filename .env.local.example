# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/wavedge?sslmode=require

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Anthropic (AI summaries, classification, digest)
ANTHROPIC_API_KEY=

# CoinGecko
COINGECKO_API_KEY=

# Stripe (Pro tier billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Email (Resend) - used for magic link auth + digest
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Telegram (alerts & digest)
TELEGRAM_BOT_TOKEN=

# Vercel Cron secret (prevents external calls to cron endpoints)
CRON_SECRET=

# App
APP_URL=http://localhost:3000
BASE_URL=https://yourdomain.com
